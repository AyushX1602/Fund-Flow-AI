// FundFlow AI — Complete Database Schema
// 12 Models, 8 Enums
// Fraud Detection & Investigation Platform for PSBs

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  ANALYST
  SUPERVISOR
  ADMIN
}

enum AccountType {
  SAVINGS
  CURRENT
  SALARY
  NRI
}

enum TransactionType {
  UPI
  NEFT
  RTGS
  IMPS
  WIRE
  CASH_DEPOSIT
  CASH_WITHDRAWAL
}

enum Channel {
  MOBILE_APP
  NET_BANKING
  ATM
  BRANCH
  POS
  API
}

enum AlertType {
  FRAUD_DETECTED
  SUSPICIOUS_PATTERN
  HIGH_VALUE
  VELOCITY_BREACH
  MULE_ACCOUNT
  RING_DETECTED
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  NEW
  REVIEWING
  ESCALATED
  RESOLVED_FRAUD
  RESOLVED_LEGITIMATE
  DISMISSED
}

enum CaseStatus {
  OPEN
  IN_PROGRESS
  PENDING_REVIEW
  CLOSED_FRAUD
  CLOSED_LEGITIMATE
  CLOSED_INCONCLUSIVE
}

// ─────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────

/// Platform users — analysts, supervisors, admins
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(ANALYST)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedAlerts Alert[]         @relation("AssignedTo")
  createdCases   Investigation[] @relation("CreatedBy")
  authoredNotes  CaseNote[]      @relation("NoteAuthor")
  auditLogs      AuditLog[]

  @@index([role])
}

/// Bank accounts under monitoring
model Account {
  id            String      @id @default(cuid())
  accountNumber String      @unique
  accountHolder String
  bankName      String
  ifscCode      String?
  accountType   AccountType @default(SAVINGS)
  balance       Float       @default(0)

  // Risk scoring
  riskScore Float   @default(0)
  muleScore Float   @default(0)
  isFrozen  Boolean @default(false)
  frozenAt  DateTime?
  frozenReason String?

  // India Stack — KYC fields
  kycType       String?  // FULL_KYC, OTP_BASED, MIN_KYC
  kycFlagged    Boolean  @default(false)
  kycFlagReason String?
  aadhaarLinked Boolean  @default(false)
  panLinked     Boolean  @default(false)
  kycFlaggedAt  DateTime?

  // India Stack — UPI VPA
  vpa String? // UPI Virtual Payment Address

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sentTransactions     Transaction[] @relation("Sender")
  receivedTransactions Transaction[] @relation("Receiver")
  outgoingEdges        FundFlowEdge[] @relation("Source")
  incomingEdges        FundFlowEdge[] @relation("Target")

  @@index([riskScore])
  @@index([muleScore])
  @@index([isFrozen])
  @@index([bankName])
}

/// Financial transactions — core entity
model Transaction {
  id            String          @id @default(cuid())
  transactionId String          @unique // External reference ID
  amount        Float
  currency      String          @default("INR")
  type          TransactionType
  channel       Channel

  // Parties
  senderAccountId   String
  senderAccount     Account @relation("Sender", fields: [senderAccountId], references: [id])
  receiverAccountId String
  receiverAccount   Account @relation("Receiver", fields: [receiverAccountId], references: [id])

  // ML scoring results
  fraudScore     Float?
  isFraud        Boolean  @default(false)
  mlModelVersion String?
  mlReasons      Json?    // SHAP reasons array [{feature, value, impact, description}]

  // India Stack — UPI VPA fields
  upiVpaSender   String?
  upiVpaReceiver String?
  pspSender      String? // Payment Service Provider (sender)
  pspReceiver    String? // Payment Service Provider (receiver)
  vpaAgeDays     Int?    // Age of sender VPA in days

  // Fund flow tracking
  chainId String? // Links transactions in same fund flow chain
  ringId  String? // Links transactions in detected fraud ring

  // Computed features (stored for audit)
  features Json?

  // Metadata
  ipAddress String?
  deviceId  String?
  location  String?
  description String?
  timestamp DateTime @default(now())

  // Relations
  alert         Alert?
  fundFlowEdges FundFlowEdge[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fraudScore])
  @@index([isFraud])
  @@index([timestamp])
  @@index([chainId])
  @@index([ringId])
  @@index([senderAccountId])
  @@index([receiverAccountId])
  @@index([type])
}

/// Fraud alerts generated by ML scoring
model Alert {
  id        String      @id @default(cuid())
  alertType AlertType
  severity  Severity
  status    AlertStatus @default(NEW)

  // Linked transaction
  transactionId String      @unique
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  // Assignment
  assignedToId String?
  assignedTo   User?   @relation("AssignedTo", fields: [assignedToId], references: [id])

  // Investigation link
  investigationId String?
  investigation   Investigation? @relation(fields: [investigationId], references: [id])

  // Details
  description String
  riskScore   Float
  mlReasons   Json? // Copy of ML reasons at alert creation time

  // Resolution
  resolvedAt DateTime?
  resolution String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([severity])
  @@index([alertType])
  @@index([createdAt])
}

/// Investigation cases — grouped alerts for review
model Investigation {
  id          String     @id @default(cuid())
  caseNumber  String     @unique
  title       String
  description String?
  status      CaseStatus @default(OPEN)
  priority    Severity   @default(MEDIUM)

  // Creator
  createdById String
  createdBy   User   @relation("CreatedBy", fields: [createdById], references: [id])

  // Relations
  alerts Alert[]
  notes  CaseNote[]

  // Resolution
  findings String?
  closedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([priority])
}

/// Notes on investigation cases
model CaseNote {
  id              String        @id @default(cuid())
  content         String
  investigationId String
  investigation   Investigation @relation(fields: [investigationId], references: [id], onDelete: Cascade)
  authorId        String
  author          User          @relation("NoteAuthor", fields: [authorId], references: [id])
  createdAt       DateTime      @default(now())
}

/// Graph edges for fund flow tracing
model FundFlowEdge {
  id      String  @id @default(cuid())
  chainId String? // Group edges into a flow chain

  // Accounts
  sourceAccountId String
  sourceAccount   Account @relation("Source", fields: [sourceAccountId], references: [id])
  targetAccountId String
  targetAccount   Account @relation("Target", fields: [targetAccountId], references: [id])

  // Transaction link
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  // Edge properties
  amount    Float
  timestamp DateTime
  hopNumber Int    @default(1)
  riskScore Float?

  createdAt DateTime @default(now())

  @@index([chainId])
  @@index([sourceAccountId])
  @@index([targetAccountId])
  @@index([timestamp])
}

/// Audit trail for all system actions
model AuditLog {
  id       String @id @default(cuid())
  action   String // FREEZE_ACCOUNT, UNFREEZE_ACCOUNT, ESCALATE_ALERT, RESOLVE_ALERT, etc.
  entity   String // "Account", "Alert", "Investigation", etc.
  entityId String
  details  Json?
  userId   String
  user     User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([action])
  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
}

/// Track simulation sessions
model SimulationRun {
  id                String   @id @default(cuid())
  status            String   @default("PENDING") // PENDING, RUNNING, COMPLETED, FAILED, STOPPED
  totalTransactions Int      @default(0)
  processedCount    Int      @default(0)
  fraudCount        Int      @default(0)
  alertCount        Int      @default(0)
  config            Json?    // Simulation parameters
  errorMessage      String?
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime @default(now())
}

/// ML model version tracking
model ModelMetadata {
  id        String   @id @default(cuid())
  modelName String   // "xgboost_v1", "isolation_forest_v1"
  version   String
  accuracy  Float?
  precision Float?
  recall    Float?
  f1Score   Float?
  auc       Float?
  isActive  Boolean  @default(false)
  trainedAt DateTime?
  metadata  Json?    // Additional model info
  createdAt DateTime @default(now())

  @@unique([modelName, version])
}

/// Configurable risk thresholds
model RiskThreshold {
  id        String   @id @default(cuid())
  name      String   @unique // "low", "medium", "high", "critical"
  minScore  Float
  maxScore  Float
  severity  Severity
  autoAlert Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Key-value system settings
model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
