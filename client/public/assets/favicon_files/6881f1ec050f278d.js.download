DD",textColor:"var(--color-heading)",backgroundColor:"#DFADDD",hasRoleTabs:!1,hasDynamicSuggestions:!1,hasSpecialFlow:!0,beta:!0,width:"120px"}],y={solve:[{id:"strategy",title:"Strategy"},{id:"product",title:"Product"},{id:"gtm",title:"GTM"},{id:"sales",title:"Sales"},{id:"competition",title:"Competition"},{id:"what-to-build",title:"What to build"}],build:[{id:"landing-page",title:"Landing page"},{id:"dashboard",title:"Dashboard"},{id:"website",title:"Website"},{id:"saas",title:"SaaS"},{id:"mobile-app",title:"Mobile App"},{id:"e-commerce",title:"E-commerce"}]},v={solve:{strategy:[{id:"s-st-1",text:"We're growing but margins are shrinking. Find out why and tell me what to fix first."},{id:"s-st-2",text:"We have 3 strategic bets for next year. Tell me which one to lead with and why."},{id:"s-st-3",text:"Write a board-ready strategy memo for our Q3 pivot — context is in this project."}],product:[{id:"s-pr-1",text:"I have a feature idea but no PRD yet. Turn my notes into something engineering can actually build from."},{id:"s-pr-2",text:"We can't agree on what's MVP and what's V1. Help us decide and explain the reasoning."},{id:"s-pr-3",text:"Our activation rate dropped after the last release. Find out what broke and what to fix."}],gtm:[{id:"s-gtm-1",text:"We're launching in 6 weeks and still don't have a clear ICP. Tell us who to go after first and why."},{id:"s-gtm-2",text:"We've tried three channels and none are working. Tell us where our customers actually are."},{id:"s-gtm-3",text:"We're ready to move upmarket to enterprise. Tell us what has to change and in what order."}],sales:[{id:"s-sa-1",text:"I have a big deal closing next week. Give me their gaps, our strongest angles, and the objections I'll face."},{id:"s-sa-2",text:"Our pipeline looks full but deals keep stalling. Tell me what's actually broken and where to focus."},{id:"s-sa-3",text:"We're pitching a new segment we've never sold into before. Tell me how to walk in ready."}],competition:[{id:"s-co-1",text:"A competitor just dropped their price. Tell me if I should respond and how."},{id:"s-co-2",text:"We keep losing deals to the same two players. Tell me exactly where we're losing and what to do about it."},{id:"s-co-3",text:"A well-funded competitor just entered our market. Tell me what they'll do first and how to stay ahead."}],"what-to-build":[{id:"s-wb-1",text:"I have 10 ideas and no clarity on which one to actually build. Tell me what to start with and why."},{id:"s-wb-2",text:"We've been debating the same feature for two months. Help us decide and move on."},{id:"s-wb-3",text:"I know what problem I want to solve. I don't know if it's a product, a feature, or a workflow."}]},build:{"landing-page":[{id:"b-lp-1",text:"I have a product but my current page isn't converting. Build me one that actually makes the case."},{id:"b-lp-2",text:"We're launching in two weeks and have no landing page. Build it from our strategy doc in this project."},{id:"b-lp-3",text:"Our hero section isn't landing with the right audience. Rebuild it around the problem we actually solve."}],dashboard:[{id:"b-db-1",text:"Our team is making decisions from spreadsheets and Slack threads. Build us a single view that fixes that."},{id:"b-db-2",text:"I need a client-facing dashboard that shows their results without giving them access to our backend."},{id:"b-db-3",text:"Our ops data lives in three different tools. Build a dashboard that pulls it into one place."}],website:[{id:"b-ws-1",text:"Our website looks like it was built in 2019 and it's costing us deals. Rebuild it from scratch."},{id:"b-ws-2",text:"We're rebranding next month and need a website that reflects who we actually are now."},{id:"b-ws-3",text:"Good prospects visit our site and don't get in touch. Fix the website so that changes."}],saas:[{id:"b-sa-1",text:"I have a validated idea and a waitlist. Build me the MVP I can put in front of them this week."},{id:"b-sa-2",text:"We've been in spreadsheets too long. Build the SaaS version of what we've been doing manually."},{id:"b-sa-3",text:"I know exactly what the product does. I just need it built — auth, billing, and all."}],"mobile-app":[{id:"b-ma-1",text:"My web app is getting traction. Build the mobile version that feels native, not ported."},{id:"b-ma-2",text:"We need a field team app that works offline and syncs when they are back online."},{id:"b-ma-3",text:"I have a marketplace idea. Build the buyer and seller experience end to end."}],"e-commerce":[{id:"b-ec-1",text:"We're selling through Instagram DMs and WhatsApp. Build us a proper store so we can stop doing this manually."},{id:"b-ec-2",text:"Our checkout is losing people. Build a storefront that's faster, cleaner, and actually converts."},{id:"b-ec-3",text:"We're ready to go D2C but have no tech. Build the store, the admin, and the checkout in one go."}]}},E=e=>w.find(t=>t.id===e);var j=e.i(378197),N=e.i(322631);function T(e){let r,i,l,n=(0,a.c)(15),{activeMode:o,onModeChange:s,className:c,variant:d}=e,m=void 0===d?"detailed":d,p=(0,h.useMatchDeviceType)("mobile");if(n[0]!==p||n[1]!==m){let e,t=w;p&&(t=w.filter(A)),n[3]!==m?(e=e=>"compact"!==m||"track"!==e.id,n[3]=m,n[4]=e):e=n[4],r=t.filter(e),n[0]=p,n[1]=m,n[2]=r}else r=n[2];let g=r,b=`${"detailed"===m?"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 px-2":"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-2 gap-3 px-2"} ${void 0===c?"":c}`;if(n[5]!==o||n[6]!==s||n[7]!==g){let e;n[9]!==o||n[10]!==s?(e=e=>(0,t.jsx)(j.AccessProtector,{featureKey:N.FEATURES.WELCOME_CHAT_INPUT,actionKey:N.FEATURE_ACTIONS.SEND,children:a=>{let{hasAccess:r,restrictionProps:i}=a;return(0,t.jsx)("div",{role:"button",tabIndex:0,onClick:()=>s(o===e.id?null:e.id),onKeyDown:t=>{("Enter"===t.key||" "===t.key)&&(t.preventDefault(),s(o===e.id?null:e.id))},className:`group gap-2 p-2.5 pb-4 transition-colors relative overflow-hidden
